# Dev-only mock gateway
# In production, this is replaced by Envoy with JWT validation, RBAC, and mTLS
FROM nginx:alpine

# Simple reverse proxy config for development
RUN cat > /etc/nginx/conf.d/default.conf <<'EOF'
server {
    listen 8443;
    server_name localhost;

    location / {
        # In production: JWT validation, RBAC enforcement, rate limiting
        # In dev: simple pass-through
        proxy_pass http://mock-app:9443;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        return 200 '{"status":"UP"}';
        add_header Content-Type application/json;
    }
}
EOF

EXPOSE 8443
CMD ["nginx", "-g", "daemon off;"]
